# EasyVariants Environment Variables Template
# Copy this file to .env and replace the values with your actual credentials.
# Do NOT commit the actual .env file to version control.

# --- CONTACT FORM INTEGRATION ---
# Keys for services like EmailJS, Web3Forms, or Formspree
# Used in contactus.html to actually send emails securely
CONTACT_API_KEY=your_api_key_here
CONTACT_SERVICE_ID=your_service_id_here
CONTACT_TEMPLATE_ID=your_template_id_here

# --- ANALYTICS & TRACKING ---
# To track 3D customizer usage and landing page conversions
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# --- BACKEND API ENDPOINTS ---
# Base URL if you plan to save user-generated 3D variants to a database
API_BASE_URL=https://api.easyvariants.com/v1
# Authentication token for API requests
API_AUTH_TOKEN=your_secure_token_here

# --- ASSET DELIVERY NETWORK (CDN) ---
# Base URL for loading heavy 3D models (GLTF/GLB) to improve performance
ASSETS_CDN_URL=https://cdn.easyvariants.com/models
